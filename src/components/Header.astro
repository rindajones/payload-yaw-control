---
interface Props {
  lang: "ja" | "en";
}

const { lang } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const menus = {
  ja: [
    { name: "概要", url: `${base}/ja/#overview` },
    { name: "制御環境", url: `${base}/ja/#environment` },
    { name: "制御結果", url: `${base}/ja/#results` },
    { name: "まとめ", url: `${base}/ja/#summary` },
  ],

  en: [
    { name: "Overview", url: `${base}/en/#overview` },
    { name: "Environment", url: `${base}/en/#environment` },
    { name: "Results", url: `${base}/en/#results` },
    { name: "Summary", url: `${base}/en/#summary` },
  ],
};

const siteName = {
  ja: "吊り荷Yaw制御",
  en: "Payload Yaw Control",
};

const currentMenus = menus[lang];
---

<header>
  <div class="container">
    <h1>
      <a href={`${base}/${lang}/`}>
        {siteName[lang]}
      </a>
    </h1>

    <div class="header-right">
      <nav class="main-nav">
        {
          currentMenus.map((menu) => (
            <a href={menu.url}>{menu.name}</a>
          ))
        }
      </nav>

      <nav class="language-nav" aria-label="言語切替">
        <a
          href={`${base}/ja/`}
          aria-current={lang === "ja" ? "page" : undefined}
        >
          日本語
        </a>

        <span>/</span>

        <a
          href={`${base}/en/`}
          aria-current={lang === "en" ? "page" : undefined}
        >
          English
        </a>
      </nav>
    </div>
  </div>
</header>