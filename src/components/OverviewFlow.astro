---
interface Props {
  lang?: "ja" | "en";
}

const { lang = "ja" } = Astro.props;

const labels =
  lang === "ja"
    ? {
        environment: {
          text: "吊り荷の制御環境の構築",
          href: "#environment",
        },
        controller: {
          text: "吊り荷の制御モデルの学習",
          href: "#control-model",
        },
        yaw: {
          text: "吊り荷 Yaw 角の推定",
          href: "#yaw-estimation",
        },
        raspberry: {
          text: "Raspberry Pi環境での制御実証",
          href: "#raspberry-pi",
        },
      }
    : {
        environment: {
          text: "Payload Control Environment",
          href: "#environment",
        },
        controller: {
          text: "Control Model Training",
          href: "#control-model",
        },
        yaw: {
          text: "Yaw Estimation",
          href: "#yaw-estimation",
        },
        raspberry: {
          text: "Control Demo on Raspberry Pi",
          href: "#raspberry-pi",
        },
      };
---

<div class="flow-chart" aria-label="プロジェクト全体の流れ">
  <!-- PC用の接続線 -->
  <svg
    class="flow-lines flow-lines-desktop"
    viewBox="0 0 1200 420"
    aria-hidden="true"
    preserveAspectRatio="none"
  >
    <defs>
      <marker
        id="arrow-desktop"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="8"
        markerHeight="8"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 Z" />
      </marker>
    </defs>

    <!-- 制御環境 → 制御モデル -->
    <path
      d="M 270 88 L 270 145"
      marker-end="url(#arrow-desktop)"
    />

    <!-- 制御モデル → Yaw推定 -->
    <path
      d="M 270 245 L 270 290"
      marker-end="url(#arrow-desktop)"
    />

    <!-- 制御モデルとYaw推定の統合 -->
    <path d="M 510 205 L 590 205 L 590 340 L 510 340" />

    <!-- 統合点 → Raspberry Pi -->
    <path
      d="M 590 272 L 665 272"
      marker-end="url(#arrow-desktop)"
    />
  </svg>

  <!-- スマートフォン用の接続線 -->
  <svg
    class="flow-lines flow-lines-mobile"
    viewBox="0 0 400 680"
    aria-hidden="true"
    preserveAspectRatio="none"
  >
    <defs>
      <marker
        id="arrow-mobile"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="8"
        markerHeight="8"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 Z" />
      </marker>
    </defs>

    <path
      d="M 200 110 L 200 170"
      marker-end="url(#arrow-mobile)"
    />

    <path
      d="M 200 280 L 200 340"
      marker-end="url(#arrow-mobile)"
    />

    <!-- 2モデルを統合してRaspberry Piへ -->
    <path
      d="M 200 450 L 200 535"
      marker-end="url(#arrow-mobile)"
    />
  </svg>
    <a class="flow-box environment" href={labels.environment.href}>
    {labels.environment.text}
    </a>
    <a class="flow-box controller" href={labels.controller.href}>
    {labels.controller.text}
    </a>

    <a class="flow-box yaw" href={labels.yaw.href}>
    {labels.yaw.text}
    </a>

    <a class="flow-box raspberry" href={labels.raspberry.href}>
    {labels.raspberry.text}
    </a>
<!--
  <div class="flow-box environment">
    {labels.environment}
  </div>

  <div class="flow-box controller">
    {labels.controller}
  </div>

  <div class="flow-box yaw">
    {labels.yaw}
  </div>

  <div class="flow-box raspberry">
    {labels.raspberry}
  </div>
-->
</div>

<style>
  .flow-chart {
    position: relative;
    width: 100%;
    max-width: 1200px;
    aspect-ratio: 1200 / 420;
    margin: 40px auto 64px;
  }

  .flow-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .flow-lines path {
    fill: none;
    stroke: #666;
    stroke-width: 3;
    vector-effect: non-scaling-stroke;
  }

  .flow-lines marker path {
    fill: #666;
    stroke: none;
  }

  .flow-lines-mobile {
    display: none;
  }

.flow-box {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;

  min-height: 84px;
  padding: 18px 28px;
  border-radius: 15px;

  background: #8b8b8b;
  color: #fff;

  font-size: 18px;
  font-weight: 500;
  line-height: 1.5;
  text-align: center;
}
  .environment,
  .controller,
  .yaw {
    left: 0;
    width: 45%;
  }

  .environment {
    top: 0;
  }

  .controller {
    top: 34%;
  }

  .yaw {
    top: 68%;
  }

  .raspberry {
    left: 56%;
    top: 46%;
    width: 43%;
    min-height: 112px;
  }

  @media (max-width: 700px) {
    .flow-chart {
      max-width: 440px;
      aspect-ratio: 400 / 680;
      margin: 32px auto 48px;
    }

    .flow-lines-desktop {
      display: none;
    }

    .flow-lines-mobile {
      display: block;
    }

    .flow-box {
      left: 5%;
      width: 90%;
      min-height: 92px;
      padding: 16px 20px;
      border-radius: 12px;
      font-size: 17px;
    }

    .environment {
      top: 0;
    }

    .controller {
      top: 25%;
    }

    .yaw {
      top: 50%;
    }

    .raspberry {
      top: 79%;
      min-height: 105px;
    }
  }
</style>