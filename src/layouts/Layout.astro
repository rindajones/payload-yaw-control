---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  lang: "ja" | "en";
}

const { title, lang } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta
      name="description"
      content="強化学習、画像によるYaw推定、Raspberry Piを組み合わせた吊り荷Yaw制御システムの技術紹介"
    />
  </head>

  <body>
    <Header lang={lang} />

    <main>
      <slot />
    </main>

    <Footer lang={lang} />
  </body>
</html>